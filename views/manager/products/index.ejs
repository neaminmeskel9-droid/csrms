<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Products</title>
</head>
<body>
    <h1>Products</h1>
    <a href="/manager/dashboard">← Dashboard</a> |
    <a href="/manager/categories">Categories</a> |
    <a href="/manager/products/create">+ Add Product</a>
    <a href="/logout" style="float:right">Logout</a>

    <table border="1" cellpadding="8" style="margin-top:20px; width:100%">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Category</th>
            <th>Cost Price</th>
            <th>Selling Price</th>
            <th>Stock</th>
            <th>Reorder Level</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
        <% products.forEach(p => { %>
        <tr>
            <td><%= p.product_id %></td>
            <td><%= p.product_name %></td>
            <td><%= p.category_name %></td>
            <td><%= p.cost_price %></td>
            <td><%= p.selling_price %></td>
            <td><%= p.quantity_available %></td>
            <td><%= p.reorder_level %></td>
            <td><%= p.status %></td>
            <td>
                <a href="/manager/products/edit/<%= p.product_id %>">Edit</a> |
                <form action="/manager/products/toggle/<%= p.product_id %>" method="POST" style="display:inline">
                    <button type="submit">
                        <%= p.status === 'active' ? 'Deactivate' : 'Activate' %>
                    </button>
                </form>
            </td>
        </tr>
        <% }) %>
    </table>
</body>
</html>